
# === [FACTOR IV: BACKING SERVICES] ===
# Внешние ресурсы, к которым приложение обращается по сетевым адресам или токенам.


# 1. Telegram Bot API (Attached Resource)
# BOT_TOKEN — production токен
BOT_TOKEN=your_production_bot_token_here

# BOT_TOKEN_TEST — тестовый токен; обязателен при BOT_MODE=test, опционален при BOT_MODE=prod
BOT_TOKEN_TEST=your_test_bot_token_here

# === [FACTOR III: CONFIG] ===
# Настройки, которые меняются между окружениями (dev/prod/test).
BOT_MODE=test

NOTIFICATION_BACKEND=telegram
# Allowed values: telegram | logging
TELEGRAM_PROXY_URL=
# Optional proxy URL for Telegram API traffic used by polling and worker notifications
RUNTIME_ALERTS_ENABLED=false
RUNTIME_ALERTS_CHAT_ID=
# Optional bot runtime alerts. Startup uses TaskIQ, shutdown is sent directly as best effort.
LEADERBOARD_WEEKLY_ENABLED=false
LEADERBOARD_WEEKLY_RECIPIENT_ID=

LEADERBOARD_WEEKLY_THREAD_ID=

LEADERBOARD_WEEKLY_CRON=0 9 * * 1
LEADERBOARD_WEEKLY_TIMEZONE=Asia/Yekaterinburg
LEADERBOARD_WEEKLY_LIMIT=10
LEADERBOARD_WEEKLY_RETRY_ENABLED=true
LEADERBOARD_WEEKLY_RETRY_MAX_RETRIES=3
LEADERBOARD_WEEKLY_RETRY_DELAY_S=30
LEADERBOARD_WEEKLY_RETRY_USE_JITTER=true
LEADERBOARD_WEEKLY_RETRY_USE_EXPONENTIAL_BACKOFF=true
LEADERBOARD_WEEKLY_RETRY_MAX_DELAY_S=300
# Weekly leaderboard scheduler settings (TaskIQ scheduler + Redis source).

# 2. Redis Backend (local runtime default for FSM state & TaskIQ broker)

FSM_STORAGE_BACKEND=redis
# Allowed values: memory | redis
# Compose services resolve Redis by the service hostname `redis`.
REDIS_URL=redis://redis:6379/0

# Telegram user id of admin recipient for role request notifications
ROLE_REQUEST_ADMIN_TG_ID=123456789
# Telegram ids that should automatically receive Admin role on registration
# Format: JSON array of integers (pydantic-settings parses it automatically)
AUTO_ADMIN_TELEGRAM_IDS=[123456789,987654321]

# 3. PostgreSQL 18 (Backing service)
# Required by Docker Compose. Keep POSTGRES_PASSWORD raw here.
POSTGRES_DB=pybot_itacadem
POSTGRES_USER=pybot
POSTGRES_PASSWORD=change_me_before_run
# Local host binding only. Production does not publish the PostgreSQL port.
POSTGRES_PORT=5432
# Compose services resolve PostgreSQL by the service hostname `postgres`.
# Percent-encode URL-special characters in the password here, while keeping
# the raw password in POSTGRES_PASSWORD.
DATABASE_URL=postgresql+asyncpg://pybot:change_me_before_run@postgres:5432/pybot_itacadem
# Optional CI/test override. It must use PostgreSQL and target `test` or a
# database name ending in `_test`; omit it locally to use Testcontainers.
# PYBOT_TEST_DATABASE_URL=postgresql+asyncpg://test:test@127.0.0.1:5432/pybot_test

# === [FACTOR XI: LOGS] ===
# Приложение не должно заботиться о ротации файлов; логи пишутся в stdout.
DEBUG=False
LOG_LEVEL=INFO
# Log output format:
# BOT_MODE and LOG_FORMAT solve different tasks:
#   BOT_MODE  - selects runtime mode and active Telegram token
#   LOG_FORMAT - selects stdout log format
# Official local parity path via `just run-parity` / Docker Compose is prod-like and uses json.
# Manual bot-only launch via `uv run run.py` may keep text as an intentional debug/DX trade-off
# when LOG_FORMAT is not set explicitly.
#   text - human-readable interactive/debug output
#   json - structured Factor XI output for Compose/prod-like runtime and production
LOG_FORMAT=json

# Rate-limiting
ENABLE_RATE_LIMIT=True

RATE_LIMIT_CHEAP=30
TIME_LIMIT_CHEAP=60

RATE_LIMIT_MODERATE=10
TIME_LIMIT_MODERATE=60

RATE_LIMIT_EXPENSIVE=3
TIME_LIMIT_EXPENSIVE=300

MAX_USER_LIMITERS=1000

# Broadcast safety settings
# Keep values in safe ranges to avoid Telegram anti-spam limits.
BROADCAST_BULK_SIZE=20
BROADCAST_MAX_CONCURRENCY=5
BROADCAST_BATCH_PAUSE_MS=1200
BROADCAST_JITTER_MIN_MS=80
BROADCAST_JITTER_MAX_MS=160
BROADCAST_RETRY_ATTEMPTS=5
BROADCAST_RETRY_MAX_WAIT_S=30

BROADCAST_ALLOWED_ROLES=Admin
# Broadcast body length before crop suffix ("..."), recommended 4093 for Telegram.
BROADCAST_MAX_TEXT_LENGTH=4093

ENABLE_LOGGING_MIDDLEWARE=True
ENABLE_USER_ACTIVITY_MIDDLEWARE=True
ENABLE_ROLE_MIDDLEWARE=True

# Health API (FastAPI)
# For Docker Compose process-type launch, set:
#   HEALTH_API_ENABLED=true
# and run compose with health profile (for example: COMPOSE_PROFILES=health).
# For local DX the official parity path is `just run-parity`, which enables this flag
# (`just run-health` remains a backward-compatible alias)
# and starts the dedicated `health` process type without extra manual setup.
# In production deploy, Ansible reads HEALTH_API_ENABLED and enables the
# `health` profile automatically.
HEALTH_API_ENABLED=False
HEALTH_API_HOST=0.0.0.0
HEALTH_API_PORT=8001

# === [DEPLOY / ORCHESTRATION ONLY] ===
# Эти переменные не materialize-ятся в AppSettings и не валидируются приложением.
# Их contract поддерживается Compose, CI/CD и deploy automation.

# TaskIQ worker concurrency on Compose/runtime level.
# Future-facing variable; the current supported maximum is 1.
TASKIQ_WORKERS=1

# Observability (Grafana + Loki + Alloy + Nginx)
# Required in production: Docker Compose will refuse to start Grafana without this value.
# Set a strong password here; it is applied once on the first container start.
GRAFANA_ADMIN_PASSWORD=change_me_before_deploy
# Production HTTPS observability domain. DNS must point this name to the shared host nginx.
PUBLIC_DOMAIN=monitoring.probochka-corp.ru
# Production compose nginx is an internal upstream for host nginx, not the public TLS endpoint.
# Local observability profile has safe Compose defaults and does not require editing these values
# just to start Grafana/Loki locally. Keep overriding them only when you intentionally need a different local ingress.
NGINX_BIND_HOST=127.0.0.1
NGINX_PORT=8088
